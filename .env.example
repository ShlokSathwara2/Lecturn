# ─── Supabase ──────────────────────────────────────
# From your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # used by the API for admin operations

# ─── AI Providers ──────────────────────────────────
GEMINI_API_KEY=your-gemini-key           # optional — direct Gemini vision
OPENROUTER_API_KEY=your-openrouter-key   # primary vision provider
GROQ_API_KEY=your-groq-key               # enrichment + Whisper transcription

# ─── App URLs (set these in Vercel/Railway env, not .env) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000    # Vercel: https://your-app.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:8000    # Railway: https://your-api.up.railway.app
